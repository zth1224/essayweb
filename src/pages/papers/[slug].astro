---
import BaseLayout from "../../layouts/BaseLayout.astro";
import LibraryBanner from "../../components/LibraryBanner.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import ReadingStatusControl from "../../components/ReadingStatusControl.astro";
import { fields } from "../../data/fields";
import { getAllPapers, getRelatedPapers, getTermsByIds, getTopicById } from "../../data/repository";
import { renderMarkdown } from "../../lib/render-markdown";
import { sitePath } from "../../lib/site-path";
import type { PaperRecord } from "../../data/types";

export function getStaticPaths() { return getAllPapers().map((paper) => ({ params: { slug: paper.slug }, props: { paper } })); }
interface Props { paper: PaperRecord }
const { paper } = Astro.props;
const field = fields.find((item) => item.id === paper.fieldIds[0])!;
const relatedTerms = getTermsByIds(paper.termIds).sort((a,b)=>b.relatedPaperIds.length-a.relatedPaperIds.length).slice(0,12);
const relatedPapers = getRelatedPapers(paper,6);
const topics = paper.topicIds.map((id)=>getTopicById(id)).filter((item)=>item !== undefined);
const date = [paper.year, paper.month ? String(paper.month).padStart(2,"0") : undefined].filter(Boolean).join(".") || "日期待补充";
---
<BaseLayout title={`${paper.title} · 论文索引`} accent={field.accent} accentSoft={field.accentSoft} description={paper.summaryMarkdown}>
  <LibraryBanner />
  <SiteHeader backHref={`/fields/${field.slug}/`} backLabel={field.titleZh} meta={`${field.code} / Paper ${paper.sourceNumber}`} discoveryField={field.id} />
  <main class="paper-detail page-shell">
    <header class="paper-detail__head"><div><p class="meta-label">{field.code} · {date} · {paper.contentState === "source-damaged" ? "Source damaged" : "Complete note"}</p><h1 class="detail-title">{paper.title}</h1></div><div class="paper-detail__status"><span class="meta-label">Reading status</span><ReadingStatusControl slug={paper.slug} title={paper.title} status={paper.status}/></div></header>
    <div class="paper-detail__meta">
      <div><span>作者 / 机构</span><strong>{paper.authorsText}</strong></div>
      <div><span>年月</span><strong>{date}</strong></div>
      <div><span>主题</span><strong>{topics.map((topic)=>topic.title).join(" · ") || "主题待整理"}</strong></div>
      <div><span>外部资料</span><strong class="source-links">{paper.sourceUrl && <a href={paper.sourceUrl} target="_blank" rel="noreferrer noopener">来源 ↗</a>}{paper.pdfUrl && <a href={paper.pdfUrl} target="_blank" rel="noreferrer noopener">PDF ↗</a>}</strong></div>
    </div>
    {paper.contentState === "source-damaged" ? (
      <section class="damage-notice"><span>SOURCE NOTE / NEEDS REPAIR</span><h2>源笔记待修复</h2><p>本页只保留 CSV 与主题页中可确认的元数据，没有发布损坏的问号正文。修复源论文库中的对应笔记后，再运行同步命令即可补回内容。</p></section>
    ) : (
      <div class="paper-detail__layout">
        <article class="paper-prose">
          <section class="paper-abstract"><span class="meta-label">一句话结论</span><div class="markdown-body markdown-body--lead" set:html={renderMarkdown(paper.summaryMarkdown)}/></section>
          {paper.sections.map((section,index)=><section id={section.id} class="paper-section"><span class="paper-section__number">{String(index+1).padStart(2,"0")}</span><div><h2>{section.title}</h2><div class="markdown-body" set:html={renderMarkdown(section.markdown)}/></div></section>)}
          <section class="related-block"><div><span class="meta-label">Related vocabulary</span><h2>关联术语</h2><ul>{relatedTerms.map((term)=><li><a href={sitePath(`/terms/${field.slug}/#${term.slug}`)}>{term.name} ↗</a></li>)}</ul></div><div><span class="meta-label">Continue reading</span><h2>关联论文</h2><ul>{relatedPapers.map((item)=><li><a href={sitePath(`/papers/${item.slug}/`)}>{item.title} ↗</a></li>)}</ul></div></section>
        </article>
        <nav class="paper-toc" aria-label="文章目录"><span class="meta-label">On this page</span>{paper.sections.map((section,index)=><a href={`#${section.id}`}><span>{String(index+1).padStart(2,"0")}</span>{section.title}</a>)}</nav>
      </div>
    )}
  </main>
</BaseLayout>
<style>
  .paper-detail{padding:0 var(--page-gutter) 5rem}.paper-detail__head{min-height:24rem;display:grid;grid-template-columns:minmax(0,1fr) auto;gap:2rem;align-items:end;padding:clamp(4rem,9vw,8rem) 0 2rem;border-bottom:1px solid var(--line-strong)}.detail-title{max-width:16ch;font-size:clamp(3rem,7vw,7.2rem)}.paper-detail__status{display:grid;gap:.5rem;justify-items:end}
  .paper-detail__meta{display:grid;grid-template-columns:1.3fr .55fr 1.2fr .7fr;border-bottom:1px solid var(--line)}.paper-detail__meta>div{min-height:6rem;display:grid;align-content:center;gap:.35rem;padding:1rem;border-right:1px solid var(--line)}.paper-detail__meta>div:first-child{padding-left:0}.paper-detail__meta>div:last-child{border:0}.paper-detail__meta span{color:var(--ink-soft);font:.62rem var(--mono);text-transform:uppercase}.paper-detail__meta strong{font-size:.76rem;font-weight:500}.source-links{display:flex;gap:1rem}.source-links a{border-bottom:1px solid}
  .paper-detail__layout{display:grid;grid-template-columns:minmax(0,1fr) 14rem;gap:clamp(3rem,7vw,8rem);padding-top:3.5rem}.paper-abstract{padding-bottom:3rem;border-bottom:1px solid var(--line-strong)}.paper-section{display:grid;grid-template-columns:3rem minmax(0,1fr);gap:1.2rem;padding:3rem 0;border-bottom:1px solid var(--line);scroll-margin-top:1rem}.paper-section__number{color:var(--accent);font:400 2rem var(--serif)}.paper-section h2,.related-block h2{margin:0 0 1rem;font:400 2.4rem/1 var(--serif)}
  .markdown-body{max-width:70ch;color:var(--ink-soft)}.markdown-body--lead{max-width:34ch;color:var(--ink);font:400 clamp(1.6rem,3vw,2.8rem)/1.15 var(--serif)}.markdown-body :global(p){margin:0 0 1rem}.markdown-body :global(ul),.markdown-body :global(ol){padding-left:1.4rem}.markdown-body :global(pre){max-width:100%;overflow:auto;padding:1rem;background:var(--ink);color:var(--surface);border-radius:.3rem}.markdown-body :global(code){font-family:var(--mono);font-size:.82em}.markdown-body :global(a){border-bottom:1px solid var(--accent)}.markdown-body :global(blockquote){margin:1.5rem 0;padding-left:1rem;border-left:3px solid var(--accent)}
  .paper-toc{position:sticky;top:1rem;align-self:start;display:grid}.paper-toc a{display:grid;grid-template-columns:2rem 1fr;gap:.5rem;padding:.75rem 0;border-top:1px solid var(--line);font-size:.74rem}.paper-toc a:last-child{border-bottom:1px solid var(--line)}.paper-toc span{font:.62rem var(--mono)}.related-block{display:grid;grid-template-columns:1fr 1fr;gap:2rem;padding-top:4rem}.related-block ul{list-style:none;margin:0;padding:0}.related-block li{padding:.75rem 0;border-top:1px solid var(--line);font:400 1.08rem/1.1 var(--serif)}
  .damage-notice{min-height:48vh;display:grid;align-content:center;max-width:62rem}.damage-notice span{color:var(--accent);font:.65rem var(--mono)}.damage-notice h2{margin:1rem 0;font:400 clamp(3rem,7vw,6rem)/.9 var(--serif)}.damage-notice p{max-width:55rem;color:var(--ink-soft)}
  @media(max-width:850px){.paper-detail__head{min-height:20rem;grid-template-columns:1fr}.paper-detail__status{justify-items:start}.paper-detail__meta{grid-template-columns:1fr 1fr}.paper-detail__meta>div:nth-child(2){border-right:0}.paper-detail__meta>div:first-child{padding-left:1rem}.paper-detail__layout{grid-template-columns:1fr}.paper-toc{display:none}}@media(max-width:580px){.related-block{grid-template-columns:1fr}.paper-section{grid-template-columns:2rem 1fr}.paper-detail__meta{grid-template-columns:1fr}.paper-detail__meta>div{border-right:0;border-bottom:1px solid var(--line)}}
</style>
