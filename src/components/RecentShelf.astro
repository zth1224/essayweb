---
import type { PaperRecord } from "../data/types";
import { sitePath } from "../lib/site-path";
interface Props { papers: PaperRecord[] }
const { papers } = Astro.props;
---
<section class="recent-shelf" aria-labelledby="recent-title">
  <header><p class="meta-label">From README / Latest six</p><h2 id="recent-title">最近收录</h2></header>
  <div>{papers.map((paper,index)=><a href={sitePath(`/papers/${paper.slug}/`)}><span>{String(index+1).padStart(2,"0")}</span><h3>{paper.title}</h3><p>{paper.year ?? "年份待补充"}{paper.month ? `.${String(paper.month).padStart(2,"0")}` : ""}</p><b>阅读笔记 ↗</b></a>)}</div>
</section>
<style>
  .recent-shelf{padding:clamp(3rem,6vw,5rem) var(--page-gutter);background:var(--ink);color:var(--surface)}
  header{display:flex;justify-content:space-between;align-items:end;gap:1rem;margin-bottom:1.5rem}.meta-label{color:#b8b7b0}h2{margin:0;font:400 clamp(2.4rem,5vw,4.8rem)/.9 var(--serif)}
  .recent-shelf>div{display:grid;grid-template-columns:repeat(3,1fr);border-top:1px solid #555;border-left:1px solid #555}
  a{min-height:12rem;display:flex;flex-direction:column;padding:1rem;border-right:1px solid #555;border-bottom:1px solid #555}a:hover{background:color-mix(in srgb,var(--accent) 65%,transparent)}
  a>span,a p,a b{font:500 .62rem/1.3 var(--mono);text-transform:uppercase}h3{margin:auto 0 .7rem;font:400 1.5rem/1 var(--serif)}a p{margin:0;color:#b8b7b0}a b{margin-top:.6rem;font-weight:500}
  @media(max-width:760px){.recent-shelf>div{grid-template-columns:1fr 1fr}}@media(max-width:480px){.recent-shelf>div{grid-template-columns:1fr}}
</style>
