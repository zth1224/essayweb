---
import type { FieldDefinition, PaperRecord } from "../data/types";
import { sitePath } from "../lib/site-path";
import ReadingStatusControl from "./ReadingStatusControl.astro";

interface Props {
  paper: PaperRecord;
  field: FieldDefinition;
  index: number;
}

const { paper, field, index } = Astro.props;
---

<article
  class:list={["paper-card", { "paper-card--featured": paper.featured }]}
  data-paper-card
  data-status={paper.status}
  data-search={[paper.title, ...paper.authors, ...paper.tags].join(" ")}
>
  <div class="paper-card__number">{String(index + 1).padStart(2, "0")}</div>
  <div class="paper-card__body">
    <div class="paper-card__meta">
      <span>{paper.featured ? "Featured note" : "Paper note"}</span>
      <span>{paper.year}</span>
    </div>
    <h2><a href={sitePath(`/papers/${paper.slug}/`)}>{paper.title}</a></h2>
    <p>{paper.summary}</p>
    <div class="paper-card__authors">{paper.authors.join(" · ")}</div>
  </div>
  <div class="paper-card__actions">
    <ReadingStatusControl slug={paper.slug} title={paper.title} status={paper.status} />
    <a class="quiet-link" href={sitePath(`/papers/${paper.slug}/`)}>查看笔记</a>
  </div>
</article>

<style define:vars={{ "card-accent": field.accent }}>
  .paper-card {
    display: grid;
    grid-template-columns: 3.2rem minmax(0, 1fr) auto;
    gap: 1rem;
    padding: 1.3rem 0;
    border-top: 1px solid var(--line);
    transition: padding var(--transition), background var(--transition);
  }
  .paper-card:last-child { border-bottom: 1px solid var(--line); }
  .paper-card:hover { padding-inline: .8rem; background: color-mix(in srgb, var(--accent-soft) 35%, transparent); }
  .paper-card__number { font-family: var(--serif); font-size: 2.2rem; color: var(--card-accent); line-height: 1; }
  .paper-card__meta { display: flex; justify-content: space-between; gap: 1rem; color: var(--ink-soft); font-family: var(--mono); font-size: .63rem; letter-spacing: .06em; text-transform: uppercase; }
  h2 { max-width: 24ch; margin: .7rem 0 .5rem; font-family: var(--serif); font-size: clamp(1.55rem, 3vw, 2.3rem); font-weight: 400; letter-spacing: -.025em; line-height: 1; }
  .paper-card--featured h2 { font-size: clamp(2rem, 4.3vw, 3.6rem); }
  p { max-width: 64ch; margin: 0; color: var(--ink-soft); font-size: .84rem; }
  .paper-card__authors { margin-top: .8rem; font-family: var(--mono); font-size: .65rem; }
  .paper-card__actions { min-width: 8.7rem; display: flex; flex-direction: column; align-items: flex-end; justify-content: space-between; gap: 1rem; }
  @media (max-width: 680px) {
    .paper-card { grid-template-columns: 2.2rem 1fr; }
    .paper-card__number { font-size: 1.7rem; }
    .paper-card__actions { grid-column: 2; min-width: 0; align-items: flex-start; }
  }
</style>
