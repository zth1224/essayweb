---
import { sitePath } from "../lib/site-path";
import type { FieldId } from "../data/types";

interface Props {
  backHref?: string;
  backLabel?: string;
  meta?: string;
  discoveryField?: FieldId;
}

const { backHref = "/", backLabel = "全部领域", meta = "Personal Knowledge Index", discoveryField } = Astro.props;
const discoveryHref = discoveryField ? `/discover/?field=${discoveryField}` : "/discover/";
---

<header class="site-header">
  <a class="site-header__back" href={sitePath(backHref)}>{backLabel}</a>
  <a class="site-header__brand" href={sitePath("/")}>论文索引 <em>Paper Index</em></a>
  <span class="site-header__meta">{meta} <a href={sitePath(discoveryHref)}>发现新论文 ↗</a></span>
</header>
